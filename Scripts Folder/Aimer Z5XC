-----------------------------------
-- DRAG & TOGGLE LOGIC
-----------------------------------
local dragging = false
local isMoved = false
local dragStart = nil
local startPos = nil

toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        isMoved = false
        dragStart = input.Position
        startPos = toggleBtn.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                
                -- If we didn't drag it, treat it as a click/toggle
                if not isMoved then
                    aimbotEnabled = not aimbotEnabled
                    FOVring.Visible = aimbotEnabled
                    
                    if aimbotEnabled then
                        toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Green
                        toggleBtn.Text = "ON"
                    else
                        toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Red
                        toggleBtn.Text = "OFF"
                    end
                end
            end
        end)
    end
end)

toggleBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            local delta = input.Position - dragStart
            
            -- If moved more than 5 pixels, consider it a drag instead of a tap
            if delta.Magnitude > 5 then
                isMoved = true
                toggleBtn.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end
    end
end)

-----------------------------------
-- ORIGINAL SCRIPT LOGIC
-----------------------------------
local function updateDrawings()
    local camViewportSize = Cam.ViewportSize
    FOVring.Position = camViewportSize / 2
end

local function lookAt(target)
    local lookVector = (target - Cam.CFrame.Position).unit
    local newCFrame = CFrame.new(Cam.CFrame.Position, Cam.CFrame.Position + lookVector)
    Cam.CFrame = newCFrame
end

local function getClosestPlayerInFOV(trg_part)
    local nearest = nil
    local last = math.huge
    local playerMousePos = Cam.ViewportSize / 2

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= Players.LocalPlayer then
            local part = player.Character and player.Character:FindFirstChild(trg_part)
            if part then
                local ePos, isVisible = Cam:WorldToViewportPoint(part.Position)
                local distance = (Vector2.new(ePos.x, ePos.y) - playerMousePos).Magnitude

                if distance < last and isVisible and distance < fov then
                    last = distance
                    nearest = player
                end
            end
        end
    end

    return nearest
end

local renderLoop = RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    
    updateDrawings()
    local closest = getClosestPlayerInFOV("Head")
    if closest and closest.Character:FindFirstChild("Head") then
        lookAt(closest.Character.Head.Position)
    end
end)

-- Kill Switch
local function onKeyDown(input)
    if input.KeyCode == Enum.KeyCode.Delete then
        renderLoop:Disconnect()
        FOVring:Remove()
        if screenGui then
            screenGui:Destroy()
        end
    end
end

UserInputService.InputBegan:Connect(onKeyDown)

